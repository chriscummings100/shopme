{
  "manifest_version": 3,
  "name": "ShopMe",
  "version": "0.1.0",
  "description": "AI shopping assistant for Waitrose",
  "permissions": [
    "webRequest",
    "cookies",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.waitrose.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["*://*.waitrose.com/*"],
      "js": ["dist/interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://*.waitrose.com/*"],
      "js": ["dist/content.js"],
      "run_at": "document_start"
    }
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShopMe"
  }
}
