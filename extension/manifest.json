{
  "manifest_version": 3,
  "name": "ShopMe",
  "version": "0.1.0",
  "description": "AI shopping assistant for Waitrose",
  "permissions": [
    "cookies",
    "tabs",
    "alarms"
  ],
  "host_permissions": [
    "*://*.waitrose.com/*"
  ],
  "background": {
    "service_worker": "dist/background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "ShopMe"
  }
}
