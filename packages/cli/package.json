{
  "name": "@chriscummings100/shopme",
  "version": "0.1.0",
  "description": "ShopMe grocery basket CLI.",
  "license": "MIT",
  "author": "Chris Cummings",
  "homepage": "https://github.com/chriscummings100/shopme#readme",
  "bugs": {
    "url": "https://github.com/chriscummings100/shopme/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chriscummings100/shopme.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "grocery",
    "shopping",
    "cli",
    "waitrose",
    "sainsburys"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "bin": {
    "shopme": "dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "prepack": "npm run build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@chriscummings100/shopme-grocery-core": "0.1.0",
    "@chriscummings100/shopme-shared": "0.1.0",
    "commander": "^14.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
