{
  "name": "@shopme/cli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "shopme": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@shopme/grocery-core": "0.1.0",
    "@shopme/shared": "0.1.0",
    "commander": "^14.0.0"
  }
}
