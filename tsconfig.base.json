{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM"
    ],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@shopme/shared": [
        "packages/shared/src/index.ts"
      ],
      "@shopme/grocery-core": [
        "packages/grocery-core/src/index.ts"
      ]
    }
  }
}
